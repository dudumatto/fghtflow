JWT_TTL_MINUTES=240
JWT_REFRESH_TTL_DAYS=14
JWT_REFRESH_COOKIE_SECURE=false

# Upload
UPLOAD_MAX_BYTES=10485760
UPLOAD_ROOT_DIR=uploads

# Financeiro
FINANCEIRO_DIAS_TOLERANCIA_INADIMPLENCIA=5
