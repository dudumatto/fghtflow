# Backend (Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/fightflow
DB_USER=fightflow
DB_PASSWORD=fightflow

# Security (DEV defaults only)
JWT_SECRET=change-me-change-me-change-me-change-me
